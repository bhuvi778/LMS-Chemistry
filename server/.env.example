PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/chemprep_lms
JWT_SECRET=change_this_super_secret_key
CLIENT_URL=http://localhost:5173

# Email Automation (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=Ace2Examz <your@gmail.com>

# Firebase Admin SDK (Push Notifications)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Agora RTC (Live Classes)
AGORA_APP_ID=your_agora_app_id
AGORA_APP_CERTIFICATE=your_agora_app_certificate

# Agora Cloud Recording (REST API) — get from console.agora.io > RESTful API
AGORA_CUSTOMER_ID=your_customer_id
AGORA_CUSTOMER_SECRET=your_customer_secret

# S3 Storage for Agora Cloud Recording
AGORA_S3_BUCKET=your-s3-bucket-name
AGORA_S3_REGION=ap-south-1
AGORA_S3_REGION_ID=14
AGORA_S3_VENDOR=1
AGORA_S3_ACCESS_KEY=your_aws_access_key
AGORA_S3_SECRET_KEY=your_aws_secret_key
